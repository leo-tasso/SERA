\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Final-year (2035) outcomes of the same neural policy trained under each ethical framework from the same 2025 state, as the mean over 6{} replication seeds (per-seed spread is reported in the text and Figure~\ref {fig:trajectories}'s bands). ``Total GDP'' is the sum of provincial GDP per capita (the system's national proxy); ``worst prov.''\ is the lowest provincial GDP per capita. Values are in the twin's native model units: disaggregated indicator levels are population-share estimates (Section~\ref {sec:data}), so absolute levels are not euro-interpretable and the meaningful comparisons are relative.}}{21}{table.caption.9}\protected@file@percent }
\newlabel{tab:headline}{{4}{21}{Final-year (\cmpFinalYear ) outcomes of the same neural policy trained under each ethical framework from the same 2025 state, as the mean over \cmpSeeds {} replication seeds (per-seed spread is reported in the text and Figure~\ref {fig:trajectories}'s bands). ``Total GDP'' is the sum of provincial GDP per capita (the system's national proxy); ``worst prov.''\ is the lowest provincial GDP per capita. Values are in the twin's native model units: disaggregated indicator levels are population-share estimates (Section~\ref {sec:data}), so absolute levels are not euro-interpretable and the meaningful comparisons are relative}{table.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Simulated trajectories 2026--2035{} under each ethical framework (same neural policy, same training budget, same budget constraint) against the baseline scenario: total national GDP (left), inter-provincial Gini on GDP per capita (center), worst-off province's GDP per capita (right). Lines are the mean over 6{} seeds; shaded bands are $\pm 1$ standard deviation across seeds, i.e.\ the run-to-run spread of the gradient-free search.}}{21}{figure.caption.10}\protected@file@percent }
\newlabel{fig:trajectories}{{2}{21}{Simulated trajectories 2026--\cmpFinalYear {} under each ethical framework (same neural policy, same training budget, same budget constraint) against the baseline scenario: total national GDP (left), inter-provincial Gini on GDP per capita (center), worst-off province's GDP per capita (right). Lines are the mean over \cmpSeeds {} seeds; shaded bands are $\pm 1$ standard deviation across seeds, i.e.\ the run-to-run spread of the gradient-free search}{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Training convergence per framework: cumulative objective improvement over the untrained network (\%) versus ES iteration, mean over 6{} seeds (bands $\pm 1$ std). Plotted as relative improvement so the four very different objective scales are comparable on one axis. Hard maximin's one-province signal gives it the least to climb on; the smoothed CVaR variant, scoring the worst 20\% of provinces, gets a denser gradient.}}{22}{figure.caption.11}\protected@file@percent }
\newlabel{fig:convergence}{{3}{22}{Training convergence per framework: cumulative objective improvement over the untrained network (\%) versus ES iteration, mean over \cmpSeeds {} seeds (bands $\pm 1$ std). Plotted as relative improvement so the four very different objective scales are comparable on one axis. Hard maximin's one-province signal gives it the least to climb on; the smoothed CVaR variant, scoring the worst 20\% of provinces, gets a denser gradient}{figure.caption.11}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {9.3}Who gains, who loses}{22}{subsection.9.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Distribution over the 110 provinces of final-year GDP per capita change versus the baseline scenario, per ethical framework (boxes: quartiles; whiskers: 5th--95th percentile). The frameworks differ not only in their means but in the \emph  {shape} of who benefits.}}{22}{figure.caption.12}\protected@file@percent }
\newlabel{fig:deltas}{{4}{22}{Distribution over the 110 provinces of final-year GDP per capita change versus the baseline scenario, per ethical framework (boxes: quartiles; whiskers: 5th--95th percentile). The frameworks differ not only in their means but in the \emph {shape} of who benefits}{figure.caption.12}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {9.4}The efficiency--equity frontier}{23}{subsection.9.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces The NSGA-II non-dominated set over uniform national lever vectors (6{} generations, population 12{}; final-year metrics), plotted as efficiency versus the floor. The set degenerates to a ray: total GDP and the worst-off province co-move (correlation 1.000) and the Gini is invariant to $\sim 10^{-6}$, so uniform national policy cannot trade efficiency against equity --- only per-province targeting can (Table~\ref {tab:headline}). The gray cross marks the baseline scenario.}}{23}{figure.caption.13}\protected@file@percent }
\newlabel{fig:pareto}{{5}{23}{The NSGA-II non-dominated set over uniform national lever vectors (\parGens {} generations, population \parPop {}; final-year metrics), plotted as efficiency versus the floor. The set degenerates to a ray: total GDP and the worst-off province co-move (correlation \parCorr ) and the Gini is invariant to $\sim 10^{-6}$, so uniform national policy cannot trade efficiency against equity --- only per-province targeting can (Table~\ref {tab:headline}). The gray cross marks the baseline scenario}{figure.caption.13}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {9.5}The frontier returns once policy can target: the clustered search}{23}{subsection.9.5}\protected@file@percent }
\newlabel{sec:clustered}{{9.5}{23}{The frontier returns once policy can target: the clustered search}{subsection.9.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces NSGA-II over \emph  {per-cluster} lever vectors (4{} k-means regional packages; 6{} generations, population 12{}). Unlike the uniform front, this one spans a real range of inequality (Gini 0.411--0.418), so efficiency (horizontal) and equity (vertical) are genuinely in tension; colour encodes the worst-off province's GDP. The red cross marks the baseline. Targeting --- not the overall intensity of national policy --- is what opens the trade-off.}}{24}{figure.caption.14}\protected@file@percent }
\newlabel{fig:paretoclustered}{{6}{24}{NSGA-II over \emph {per-cluster} lever vectors (\parcClusters {} k-means regional packages; \parGens {} generations, population \parPop {}). Unlike the uniform front, this one spans a real range of inequality (Gini \parcGiniLo --\parcGiniHi ), so efficiency (horizontal) and equity (vertical) are genuinely in tension; colour encodes the worst-off province's GDP. The red cross marks the baseline. Targeting --- not the overall intensity of national policy --- is what opens the trade-off}{figure.caption.14}{}}
